{
  "openapi": "3.0.3",
  "info": {
    "title": "Transactions Timeline API",
    "description": "API endpoints for bank transactions timeline data",
    "version": "1.0.0",
    "contact": {
      "name": "API Support",
      "email": "support@factora.com"
    }
  },
  "servers": [
    {
      "url": "https://api.factora.com",
      "description": "Production server"
    },
    {
      "url": "https://staging-api.factora.com",
      "description": "Staging server"
    }
  ],
  "paths": {
    "/api/customers/{customerId}/transactions-timeline": {
      "get": {
        "summary": "Get bank transactions timeline for a customer",
        "description": "Returns bank transactions with KPIs including accounts, total credits, and net cash flow",
        "operationId": "getTransactionsTimeline",
        "tags": ["Transactions Timeline"],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "description": "Customer identifier (slug format)",
            "schema": {
              "type": "string",
              "example": "euromed-supplies-gmbh"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "description": "Start date for transactions (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2025-07-01"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "End date for transactions (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2025-07-31"
            }
          },
          {
            "name": "account",
            "in": "query",
            "required": false,
            "description": "Filter by specific account number",
            "schema": {
              "type": "string",
              "example": "GR12 0110 0120 0000 0001 2300 695"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transactions timeline retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionsTimelineResponse"
                },
                "example": {
                  "kpis": {
                    "accounts": [
                      "GR12 0110 0120 0000 0001 2300 695",
                      "GR45 0171 0120 0000 0009 8765 432"
                    ],
                    "totalCredits": 22380.0,
                    "netCashFlow": -13454.62
                  },
                  "transactions": [
                    {
                      "id": "t1",
                      "date": "2025-07-28",
                      "account": "GR12 0110 0120 0000 0001 2300 695",
                      "description": "Card purchase - Office Supplies",
                      "amountEur": -284.12,
                      "category": "expense"
                    },
                    {
                      "id": "t2",
                      "date": "2025-07-27",
                      "account": "GR12 0110 0120 0000 0001 2300 695",
                      "description": "Wire - Customer Invoice #1842",
                      "amountEur": 12840.0,
                      "category": "income"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Customer not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TransactionsTimelineResponse": {
        "type": "object",
        "required": ["kpis", "transactions"],
        "properties": {
          "kpis": {
            "$ref": "#/components/schemas/TransactionKPIs"
          },
          "transactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BankTransaction"
            },
            "description": "Array of bank transactions sorted by date (newest first)"
          }
        }
      },
      "TransactionKPIs": {
        "type": "object",
        "required": ["accounts", "totalCredits", "netCashFlow"],
        "properties": {
          "accounts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of account numbers",
            "example": [
              "GR12 0110 0120 0000 0001 2300 695",
              "GR45 0171 0120 0000 0009 8765 432"
            ]
          },
          "totalCredits": {
            "type": "number",
            "description": "Total credit amount in EUR for the period",
            "example": 22380.0
          },
          "netCashFlow": {
            "type": "number",
            "description": "Net cash flow (credits - debits) in EUR",
            "example": -13454.62
          }
        }
      },
      "BankTransaction": {
        "type": "object",
        "required": [
          "id",
          "date",
          "account",
          "description",
          "amountEur",
          "category"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique transaction identifier",
            "example": "t1"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Transaction date in ISO format",
            "example": "2025-07-28"
          },
          "account": {
            "type": "string",
            "description": "Bank account number",
            "example": "GR12 0110 0120 0000 0001 2300 695"
          },
          "description": {
            "type": "string",
            "description": "Transaction description",
            "example": "Card purchase - Office Supplies"
          },
          "amountEur": {
            "type": "number",
            "description": "Transaction amount in EUR (positive for credit, negative for debit)",
            "example": -284.12
          },
          "category": {
            "type": "string",
            "enum": ["income", "expense", "transfer"],
            "description": "Transaction category",
            "example": "expense"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code",
            "example": "CUSTOMER_NOT_FOUND"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Customer with ID 'euromed-supplies-gmbh' not found"
          },
          "details": {
            "type": "string",
            "description": "Additional error details",
            "example": "Please verify the customer ID and try again"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Transactions Timeline",
      "description": "Endpoints for bank transactions timeline data"
    }
  ]
}
