# -----------------------------------------------------------------------
# Factora Backend — Environment Variables
# Copy this file to .env and fill in all values before starting the app.
# Never commit .env to version control.
# -----------------------------------------------------------------------

# --- Supabase / PostgreSQL ---
SUPABASE_URI=postgresql+asyncpg://postgres:<password>@<host>:5432/<db>
SUPABASE_URI_SHARED_POOLER=postgresql+asyncpg://postgres:<password>@<host>:6543/<db>
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=<supabase-service-role-key>
SUPABASE_BUCKET=<storage-bucket-name>

# Used by Alembic for synchronous migrations (port 5432, direct connection)
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:<password>@<host>:5432/<db>

# --- Brevo (email + SMS) ---
BREVO_API_KEY=<your-brevo-api-key>
BREVO_SMTP_KEY=<your-brevo-smtp-key>
BREVO_SENDER_EMAIL=<sender@yourdomain.com>
BREVO_SENDER_NAME=<Sender Display Name>

# --- GEMI (Greek Business Registry) ---
GEMH_API_KEY=<your-gemi-api-key>

# --- AADE / myDATA (Greek Tax Authority) ---
AADE_USERNAME=<your-aade-username>
AADE_SUBSCRIPTION_KEY=<your-aade-subscription-key>

# --- SaltEdge (Open Banking) ---
SALTEDGE_APP_ID=<your-saltedge-app-id>
SALTEDGE_SECRET=<your-saltedge-secret>

# --- AI: Gemini, OpenAI, or Anthropic (Claude) ---
# LLM_PROVIDER=gemini | openai | anthropic
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514

# EMBEDDING_PROVIDER=gemini | openai
# Vector column width (must match DB after migration; default 768).
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIMENSIONS=768

# --- Gmail OAuth + Pub/Sub ---
# Fernet key for encrypting refresh tokens: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GMAIL_TOKEN_ENCRYPTION_KEY=
# Must match an authorized redirect URI in Google Cloud Console (Gmail API enabled).
GOOGLE_GMAIL_REDIRECT_URI=https://<your-api-domain>/v1/integrations/gmail/callback
# Pub/Sub push subscription OIDC audience (often the push endpoint URL). Leave empty in dev to skip JWT verify.
GMAIL_PUBSUB_VERIFICATION_AUDIENCE=

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pin to your Stripe dashboard API version; must match event payloads used by webhooks
STRIPE_API_VERSION=2026-02-25.clover

# --- Auth ---
# Server-side pepper mixed into Argon2 password hashes.  Must be >= 16 chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CODE_PEPPER=<at-least-16-random-characters>

# HS256 signing key for JWT access tokens.  Must be >= 32 random bytes.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=<at-least-32-random-bytes>

# --- Google OAuth (required for Google Sign-In) ---
# Obtain from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   https://<your-api-domain>/v1/auth/google/callback   (Sign-In)
#   https://<your-api-domain>/v1/integrations/gmail/callback   (Gmail connect)
GOOGLE_CLIENT_ID=<your-google-oauth2-client-id>
GOOGLE_CLIENT_SECRET=<your-google-oauth2-client-secret>

# --- URLs ---
# Canonical frontend URL used in outbound email links (password reset, etc.).
#   Production:   https://app.factora.eu
#   Development:  https://<ngrok-subdomain>.ngrok-free.app  OR  http://localhost:3000
FRONTEND_BASE_URL=https://<your-frontend-domain>

# --- Environment ---
# Controls external API behaviour, demo guards, and feature flags.
#
#   production  — real API calls, real emails, real data.
#   development — real API calls, local URLs; relaxed security checks.
#   demo        — domain data from PostgreSQL (seed with scripts/seed_demo_db.py); AADE/SaltEdge/GEMI
#                 HTTP clients return fixtures from app/core/demo_fixtures/ (no real calls to those APIs);
#                 agents may use @demo_fixture; emails are logged; X-Demo-Mode: true on responses.
#
# NEVER set demo=production or vice-versa.  Use separate .env files per environment.
#
# Three-environment operations (outside this repo):
#   • Supabase: use at least two projects (development + production). Run Alembic against each.
#     Point SUPABASE_URI / ALEMBIC_DATABASE_URL at the matching project; keep secrets in GitHub
#     (repository or environment-scoped) and local .env — never commit real credentials.
#   • Vercel: Preview/Development env vars → dev API base URL; Production → prod API. For demo
#     deployments, point the frontend at a demo API host with ENVIRONMENT=demo on the backend.
#     Avoid NEXT_PUBLIC_SALTEDGE_CUSTOMER_ID unless debugging; in demo the first SaltEdge
#     customer from fixtures is used (see app/core/demo_constants.py).
#   • GitHub: CI and deploy secrets per environment; rotate keys in provider consoles.
ENVIRONMENT=production

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Leave empty to deny all cross-origin requests (production default).
#   Production:   https://app.factora.eu,https://www.factora.eu
#   Demo:         https://demo.factora.eu
#   Development:  http://localhost:3000
CORS_ORIGINS=

# --- Proxy / Host Security ---
# Comma-separated trusted proxy IPs or CIDRs.
# Docker bridge network: 172.16.0.0/12
# Use * only in local dev.
TRUSTED_PROXIES=172.16.0.0/12

# Comma-separated allowed Host header values for TrustedHostMiddleware.
# Use * only in local dev.
#   Production: app.factora.eu,api.factora.eu
ALLOWED_HOSTS=*
